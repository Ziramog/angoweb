---
<section class="section applications-section" id="aplicaciones">
    <div class="container">
        <div class="section-kicker" data-reveal>Aplicaciones</div>
        <div class="section-heading-row">
            <h2 class="section-title" data-reveal>Industriales</h2>
            <p class="section-subtitle" data-reveal style="--i: 1">Soluciones confiables para equipos de combusti&oacute;n interna di&eacute;sel o nafteros, con configuraciones de 1, 2 o 3 discos.</p>
        </div>

        <div class="apps-grid" data-reveal style="--i: 2">
            <article class="app-module">
                <div class="app-header">
                    <i class="ph-fill ph-drop app-icon"></i>
                    <h3>Bombas centr&iacute;fugas</h3>
                </div>
                <div class="app-photo-container">
                    <img src="/bomba.png" alt="Bombas centrífugas" class="app-photo">
                </div>
            </article>
            <article class="app-module">
                <div class="app-header">
                    <i class="ph-fill ph-engine app-icon"></i>
                    <h3>Compresores</h3>
                </div>
                <div class="app-photo-container">
                    <img src="/compresor.png" alt="Compresores" class="app-photo">
                </div>
            </article>
            <article class="app-module">
                <div class="app-header">
                    <i class="ph-fill ph-fan app-icon"></i>
                    <h3>Ventiladores industriales</h3>
                </div>
                <div class="app-photo-container">
                    <img src="/ventilador.png" alt="Ventiladores industriales" class="app-photo">
                </div>
            </article>
            <article class="app-module">
                <div class="app-header">
                    <i class="ph-fill ph-tractor app-icon"></i>
                    <h3>Implementos agr&iacute;colas</h3>
                </div>
                <div class="app-photo-container">
                    <img src="/tractor.png" alt="Implementos agrícolas" class="app-photo">
                </div>
            </article>
            <article class="app-module">
                <div class="app-header">
                    <i class="ph-fill ph-lightning app-icon"></i>
                    <h3>Generadores</h3>
                </div>
                <div class="app-photo-container">
                    <img src="/generador.png" alt="Generadores" class="app-photo">
                </div>
            </article>
            <article class="app-module">
                <div class="app-header">
                    <i class="ph-fill ph-truck app-icon"></i>
                    <h3>Equipos especiales</h3>
                </div>
                <div class="app-photo-container">
                    <img src="/equipo-especial.png" alt="Equipos especiales" class="app-photo">
                </div>
            </article>
        </div>
    </div>
</section>
