---
---
<section class="hero-section" id="tomas-de-fuerza">
    <div class="blueprint-grid"></div>
    <div class="drawing-mark drawing-mark-a"></div>
    <div class="drawing-mark drawing-mark-b"></div>

    <div class="container hero-inner">
        <div class="hero-content">
            <span class="eyebrow" data-reveal>FABRICACI&Oacute;N DE PRECISI&Oacute;N</span>
            <h1 class="hero-title" data-reveal style="--i: 1">Tomas de fuerza con embrague para transmisi&oacute;n de potencia industrial</h1>
            <p class="hero-subtitle" data-reveal style="--i: 2">Equipos robustos para motores di&eacute;sel y nafteros, seleccionados seg&uacute;n torque, RPM, tipo de carga, frecuencia de acoplamiento y carcaza SAE.</p>
            <div class="hero-actions" data-reveal style="--i: 3">
                <a href="#contacto" class="btn btn-primary"><i class="ph ph-arrow-square-out"></i> Solicitar selecci&oacute;n t&eacute;cnica</a>
                <a href="#modelos" class="btn btn-outline"><i class="ph ph-table"></i> Ver modelos disponibles</a>
            </div>
            <div class="hero-proof" data-reveal style="--i: 4">
                <span>Ingenier&iacute;a</span>
                <span>Precisi&oacute;n</span>
                <span>Confiabilidad</span>
            </div>
        </div>

        <div class="hero-visual" aria-hidden="true">
        </div>
    </div>
</section>

<!-- Stats Counter Band -->
<div class="specs-band stats-band" style="padding: var(--space-8) 0;">
    <div class="container specs-band-inner" style="justify-content: space-around;">
        <div class="stat-item">
            <span class="stat-number" data-target="60" data-suffix="+">+0</span>
            <span class="stat-label">AÑOS DE EXPERIENCIA</span>
        </div>
        <div class="spec-divider"></div>
        <div class="stat-item">
            <span class="stat-number" data-target="3600" data-prefix="+">+0</span>
            <span class="stat-label">EQUIPOS INSTALADOS</span>
        </div>
        <div class="spec-divider"></div>
        <div class="stat-item">
            <span class="stat-number" data-target="100" data-suffix="%">0%</span>
            <span class="stat-label">INDUSTRIA ARGENTINA</span>
        </div>
        <div class="spec-divider"></div>
        <div class="stat-item">
            <span class="stat-number">24/7</span>
            <span class="stat-label">SOPORTE TÉCNICO</span>
        </div>
    </div>
</div>
