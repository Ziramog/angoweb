---
<section class="section brand-section" id="marca">
    <div class="container">
        <div class="brand-grid">
            <div class="brand-content">
                <div class="section-kicker" data-reveal>Nuestra Garant&iacute;a</div>
                <h2 class="section-title" data-reveal style="--i: 1">Marca Registrada</h2>
                <p class="section-subtitle" data-reveal style="--i: 2"><strong>RG</strong> es nuestra marca registrada que contin&uacute;a siendo una insignia de calidad para las industrias y para nuestra propia empresa.</p>
                
                <div class="brand-traits-container" data-reveal style="--i: 3">
                    <img src="/render-rg-2.png" alt="Marca Registrada RG" class="brand-inline-logo">
                    <div class="brand-traits">
                        <div class="trait-item">
                            <i class="ph-fill ph-shield-check"></i>
                            <span>Resistencia</span>
                        </div>
                        <div class="trait-item">
                            <i class="ph-fill ph-handshake"></i>
                            <span>Confianza</span>
                        </div>
                        <div class="trait-item">
                            <i class="ph-fill ph-lock-key"></i>
                            <span>Seguridad</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
